# zDash Codex Cloud Safe Environment Defaults
# Non-secret defaults only. Do not paste real secrets into this file.

APP_ENV=development
LOG_LEVEL=INFO

# Trading safety
DRY_RUN=true
LIVE_TRADING_ACK=false
RISK_GUARDIAN_ENABLED=true

# Social safety
SOCIAL_DRY_RUN=true
SOCIAL_APPROVAL_REQUIRED=true
SOCIAL_AUTO_POST_ENABLED=false

# IoT safety
IOT_DRY_RUN=true
IOT_REQUIRE_CONFIRMATION=true

# Deployment/support safety
DEPLOYMENT_PACK_DRY_RUN=true
DEPLOYMENT_PACK_INCLUDE_SECRETS=false
SUPPORT_BUNDLE_DRY_RUN=true
SUPPORT_BUNDLE_INCLUDE_SECRETS=false
CUSTOMER_INSTALLER_DRY_RUN=true
CUSTOMER_INSTALLER_ALLOW_REAL_INSTALL=false

# Updates safety
UPDATE_DRY_RUN=true
UPDATE_AUTO_APPLY=false
UPDATE_ROLLBACK_DRY_RUN=true

# Governance/compliance safety
AUDITOR_READ_ONLY=true
EVIDENCE_REDACTION_STRICT=true
CERTIFICATION_FAIL_CLOSED=true
POLICY_FAIL_CLOSED=true

# Fleet/relay safety
FLEET_REMOTE_DIAGNOSTICS_DRY_RUN=true
RELAY_COMMANDS_DRY_RUN=true
RELAY_ALLOW_SHELL=false
RELAY_REQUIRE_MUTATION_APPROVAL=true

# Security/data safety
RAG_REDACTION_STRICT=true
RAG_ALLOW_SECRET_RETRIEVAL=false
SECURITY_ACTIVE_SCANNING=false
DLP_STRICT=true

# Placeholder only. Set real secrets in Codex Cloud environment settings, not in git.
CLAUDE_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
CLOUDFLARE_API_TOKEN=
DATABASE_URL=sqlite:///./zdash.db
