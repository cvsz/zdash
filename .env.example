APP_NAME=zDash
APP_ENV=development
LOG_LEVEL=INFO

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
AI_PROVIDER=mock

DRY_RUN=true
LIVE_TRADING_ACK=false

RISK_GUARDIAN_ENABLED=true
MAX_DAILY_DRAWDOWN_PERCENT=5
MAX_TOTAL_DRAWDOWN_PERCENT=20
EMERGENCY_KILL_SWITCH_DRAWDOWN_PERCENT=50

SOFT_HALT_DRAWDOWN_LEVEL_1=5
SOFT_HALT_DRAWDOWN_LEVEL_2=10
SOFT_HALT_DRAWDOWN_LEVEL_3=20

ALLOW_MANUAL_RESUME=true
REQUIRE_RESUME_REASON=true

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Bangkok
SCHEDULER_DEFAULT_MAX_RUNTIME_SECONDS=300
SCHEDULER_ALLOW_MANUAL_RUN=true
SCHEDULER_STORE=in_memory

FRIDAY_AGENT_ENABLED=true

IOT_ENABLED=true
IOT_DRY_RUN=true
IOT_REQUIRE_CONFIRMATION=true

TAPO_USERNAME=
TAPO_PASSWORD=
TAPO_DEVICE_IP=
TAPO_DEVICE_ALIAS=zdash-power-node

NSSM_SERVICE_NAME=zdash-janie-server
NSSM_DISPLAY_NAME=zDash Janie Server
NSSM_DESCRIPTION=zDash Janie Server and Agent Runtime
NSSM_BACKEND_HOST=127.0.0.1
NSSM_BACKEND_PORT=8000

BACKTESTING_ENABLED=true
BACKTEST_DATASET_SOURCE=mock
BACKTEST_DEFAULT_SYMBOL=XAUUSD
BACKTEST_DEFAULT_TIMEFRAME=M5
BACKTEST_INITIAL_BALANCE=10000
BACKTEST_DEFAULT_RISK_PER_TRADE_PERCENT=1
BACKTEST_COMMISSION_PER_TRADE=0
BACKTEST_SPREAD_POINTS=25
BACKTEST_SLIPPAGE_POINTS=5
PRIMARY_STRATEGY=ob_aggressive
ALLOW_STRATEGY_PROMOTION=false
MIN_PROMOTION_TRADES=50
MIN_PROMOTION_WIN_RATE=45
MIN_PROMOTION_PROFIT_FACTOR=1.2
MAX_PROMOTION_DRAWDOWN_PERCENT=20
MAX_PROMOTION_CONSECUTIVE_LOSSES=8
OPTIMIZER_MAX_COMBINATIONS=100
OPTIMIZER_SORT_METRIC=profit_factor

CONTENT_PIPELINE_ENABLED=true
CONTENT_STORE=in_memory
EDITOR_AGENT_ENABLED=true
GRAPHIC_AGENT_ENABLED=true
SOCIAL_AGENT_ENABLED=true
CONTENT_DEFAULT_BRAND=zDash
CONTENT_DEFAULT_LANGUAGE=en
CONTENT_DEFAULT_TONE=professional
CONTENT_REQUIRE_POLICY_CHECK=true
IMAGE_GENERATION_PROVIDER=mock
IMAGE_DRY_RUN=true
IMAGE_OUTPUT_DIR=backend/data/content/images
SOCIAL_PROVIDER=mock
SOCIAL_DRY_RUN=true
SOCIAL_APPROVAL_REQUIRED=true
SOCIAL_AUTO_POST_ENABLED=false
SOCIAL_DEFAULT_PLATFORMS=x,tiktok,facebook,instagram,linkedin
SOCIAL_X_API_KEY=
SOCIAL_X_API_SECRET=
SOCIAL_TIKTOK_ACCESS_TOKEN=
SOCIAL_FACEBOOK_ACCESS_TOKEN=
SOCIAL_INSTAGRAM_ACCESS_TOKEN=
SOCIAL_LINKEDIN_ACCESS_TOKEN=
