APP_NAME=zDash
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./zdash.db
POSTGRES_USER=zdash
POSTGRES_PASSWORD=change-me
POSTGRES_DB=zdash
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
AUTH_ENABLED=true
JWT_SECRET_KEY=change-me-super-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
DEFAULT_ADMIN_EMAIL=admin@zdash.local
DEFAULT_ADMIN_PASSWORD=change-me-now
RBAC_ENABLED=true
AUDIT_LOG_ENABLED=true
AUDIT_PERSISTENCE_ENABLED=true
METRICS_ENABLED=true
METRICS_AUTH_REQUIRED=true
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DRY_RUN=true
LIVE_TRADING_ACK=false
RISK_GUARDIAN_ENABLED=true
IOT_DRY_RUN=true
IOT_REQUIRE_CONFIRMATION=true
SOCIAL_DRY_RUN=true
SOCIAL_APPROVAL_REQUIRED=true
SOCIAL_AUTO_POST_ENABLED=false
PRODUCTION_SAFETY_LOCK=true
