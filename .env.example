APP_NAME=zDash
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8004

MULTI_TENANT_ENABLED=true
DEFAULT_ORG_NAME=zDash Local
DEFAULT_WORKSPACE_NAME=Main Workspace
TENANT_HEADER_NAME=X-ZDash-Tenant
WORKSPACE_HEADER_NAME=X-ZDash-Workspace
WORKER_ENABLED=true
WORKER_QUEUE_BACKEND=redis
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_TASK_TIMEOUT_SECONDS=300
WORKER_MAX_RETRIES=3
REALTIME_ENABLED=true
REALTIME_EVENT_BUFFER_SIZE=500
NOTIFICATIONS_ENABLED=true
NOTIFICATION_DRY_RUN=true
ALERT_RULES_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
WEBHOOK_NOTIFICATIONS_ENABLED=false
WEBHOOK_URL=
CLOUDFLARE_ENABLED=false
CLOUDFLARE_DRY_RUN=true
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_NAME=zdash
CLOUDFLARE_HOSTNAME=zdash.example.com
K8S_NAMESPACE=zdash
K8S_IMAGE_TAG=latest
RELEASE_CHANNEL=local
RELEASE_VERSION=0.9.0-phase9

# Phase 11 scaffold flags
AIOPS_ENABLED=true
GOVERNANCE_ENABLED=true
COMPLIANCE_ENABLED=true

# Phase 14 desktop/launch/distribution defaults
DESKTOP_APP_ENABLED=true
DESKTOP_LOCAL_BRIDGE_ENABLED=false
DESKTOP_LOCAL_BRIDGE_DRY_RUN=true
DESKTOP_OFFLINE_MODE_ENABLED=true
DESKTOP_AUTO_UPDATE_ENABLED=false
PUBLIC_LAUNCH_ENABLED=true
PUBLIC_LAUNCH_MODE=waitlist
PUBLIC_DEMO_MODE=true
PUBLIC_SANDBOX_ONLY=true
WAITLIST_ENABLED=true
INVITE_CODES_ENABLED=true
TELEMETRY_ENABLED=true
TELEMETRY_MODE=privacy_safe
TELEMETRY_COLLECT_SECRETS=false

# Phase 16 Sovereign / Edge / Global Ops
SOVEREIGN_MODE_ENABLED=true
SOVEREIGN_FAIL_CLOSED=true
DEFAULT_DATA_REGION=local
ALLOWED_DATA_REGIONS=local,us,eu,apac
DISALLOWED_DATA_REGIONS=
DATA_RESIDENCY_ENFORCEMENT_ENABLED=true
CROSS_REGION_SYNC_ENABLED=false
CROSS_REGION_SYNC_DRY_RUN=true
CUSTOMER_MANAGED_KEYS_ENABLED=true
KMS_PROVIDER=mock
KMS_DRY_RUN=true
EDGE_RUNNERS_ENABLED=true
EDGE_RUNNER_DRY_RUN=true
ONPREM_APPLIANCE_ENABLED=true
ONPREM_EXCLUDE_SECRETS=true
GLOBAL_OPS_ENABLED=true
GLOBAL_ROLLOUT_DRY_RUN=true

DIGITAL_TWIN_ENABLED=true
DIGITAL_TWIN_MODE=advisory
DIGITAL_TWIN_DRY_RUN=true
DIGITAL_TWIN_REQUIRE_EVIDENCE=true
DIGITAL_TWIN_MAX_GRAPH_NODES=5000
DIGITAL_TWIN_MAX_GRAPH_EDGES=20000
IMPACT_PROPAGATION_ENABLED=true
BLAST_RADIUS_ANALYSIS_ENABLED=true
TWIN_SNAPSHOT_ENABLED=true
TWIN_REPORTS_ENABLED=true
MACRO_SIMULATION_ENABLED=true
MACRO_SIMULATION_DRY_RUN=true
MACRO_SIMULATION_MAX_RUNS_PER_REQUEST=10
MARKET_SHOCK_SIMULATION_ENABLED=true
POLICY_SCENARIO_SIMULATION_ENABLED=true
SUPPLY_DEMAND_SIMULATION_ENABLED=true
REGIONAL_SCENARIO_SIMULATION_ENABLED=true
CONTINUOUS_PLANNING_ENABLED=true
CONTINUOUS_PLANNING_MODE=advisory
CONTINUOUS_PLANNING_DRY_RUN=true
CONTINUOUS_PLANNING_REQUIRE_APPROVAL=true
CONTINUOUS_PLANNING_CYCLE_INTERVAL_DAYS=7
STRATEGY_MEMORY_ENABLED=true
DECISION_LINEAGE_ENABLED=true
STRATEGIC_TRADEOFF_ENABLED=true
ROADMAP_SIMULATION_ENABLED=true
STRATEGY_WAR_ROOM_ENABLED=true
WAR_ROOM_MAX_ACTIVE_SESSIONS=10
